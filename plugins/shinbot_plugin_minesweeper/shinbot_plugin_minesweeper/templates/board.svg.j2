<svg xmlns="http://www.w3.org/2000/svg" width="{{ width }}" height="{{ height }}" viewBox="0 0 {{ width }} {{ height }}">
  <style>
    text {
      font-family: Inter, 'Noto Sans CJK SC', 'Microsoft YaHei', sans-serif;
    }
    .title {
      font-size: 18px;
      font-weight: 700;
      fill: {{ title_fill }};
    }
    .meta {
      font-size: 13px;
      fill: {{ meta_fill }};
    }
    .coord {
      font-size: 12px;
      fill: {{ coord_fill }};
      font-weight: 600;
    }
    .cellText {
      font-size: 15px;
      font-weight: 700;
      text-anchor: middle;
      dominant-baseline: central;
    }
  </style>
  <rect width="100%" height="100%" rx="0" fill="{{ background }}"/>
  <text x="18" y="32" class="title">{{ title }}</text>
  <text x="18" y="56" class="meta">{{ subtitle }}</text>
  {% for column in columns %}
  <text x="{{ "%.1f"|format(column.x) }}" y="{{ column.y }}" class="coord" text-anchor="middle">{{ column.label }}</text>
  {% endfor %}
  {% for row in rows %}
  <text x="{{ row.x }}" y="{{ "%.1f"|format(row.y) }}" class="coord" text-anchor="middle" dominant-baseline="central">{{ row.label }}</text>
  {% endfor %}
  {% for cell in cells %}
  <rect x="{{ cell.x }}" y="{{ cell.y }}" width="{{ cell.size }}" height="{{ cell.size }}" rx="4" fill="{{ cell.fill }}" stroke="{{ cell.stroke }}"/>
  <text x="{{ "%.1f"|format(cell.text_x) }}" y="{{ "%.1f"|format(cell.text_y) }}" class="cellText" fill="{{ cell.text_fill }}">{{ cell.text }}</text>
  {% endfor %}
</svg>
